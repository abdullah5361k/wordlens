{
  "manifest_version": 3,
  "name": "WordLens",
  "version": "1.1.0",
  "description": "Highlight any word while reading online or in PDFs to instantly get its meaning in context.",
  "permissions": [
    "storage",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://api.groq.com/*",
    "*://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["pdfjs/pdf.worker.min.js", "viewer.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "WordLens"
  }
}
